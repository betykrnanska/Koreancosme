/* ══ HERO PARTICLE OVERLAY (over real video) ══ */
(function(){
  const cv=document.getElementById('heroParticleCanvas'), ctx=cv.getContext('2d');
  let W,H,t=0;
  function resize(){W=cv.width=cv.offsetWidth;H=cv.height=cv.offsetHeight;}
  resize(); window.addEventListener('resize',resize);

  /* floating iridescent specks */
  const specks=Array.from({length:260},()=>({
    x:Math.random(), y:Math.random()+.2,
    r:.25+Math.random()*1.4,
    a:.03+Math.random()*.38,
    vy:.04+.28*Math.random(),
    vx:(Math.random()-.5)*.12,
    hue:Math.random()*360
  }));

  function draw(){
    ctx.clearRect(0,0,W,H);

    const hue=(t*10)%360;

    /* subtle iridescent corner blooms */
    [[W*.85,H*.25,H*.55,.12],[W*.1,H*.6,H*.45,.07]].forEach(([bx,by,br,ba],i)=>{
      const g=ctx.createRadialGradient(bx,by,0,bx,by,br);
      g.addColorStop(0,`hsla(${(hue+i*120)%360},55%,80%,${ba+.03*Math.sin(t*.4+i)})`);
      g.addColorStop(1,'transparent');
      ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
    });

    /* HUD grid — right side only, very faint */
    ctx.strokeStyle='rgba(200,205,220,.04)'; ctx.lineWidth=.5;
    for(let gx=W*.55;gx<W*.95;gx+=W*.055){ctx.beginPath();ctx.moveTo(gx,H*.08);ctx.lineTo(gx,H*.88);ctx.stroke();}
    for(let gy=H*.08;gy<H*.88;gy+=H*.08){ctx.beginPath();ctx.moveTo(W*.55,gy);ctx.lineTo(W*.95,gy);ctx.stroke();}

    /* data readout — top right */
    ctx.font='8px "Space Mono",monospace';
    ['HYDRATION: 98.2%','LUMINANCE: ██████░░','PEPTIDE BOND: ACTIVE','SKIN TEMP: 36.4°C','SYN-COLLAGEN: ON'].forEach((l,i)=>{
      const lh=(hue+i*44)%360;
      ctx.globalAlpha=.18+.06*Math.sin(t*.7+i*.6);
      ctx.fillStyle=`hsl(${lh},50%,78%)`;
      ctx.fillText(l,W*.62,H*.22+i*20);
    });
    ctx.globalAlpha=1;

    /* iridescent rings — top right corner accent */
    const rx=W*.78, ry=H*.3;
    for(let i=0;i<3;i++){
      const r=Math.min(W,H)*(.08+i*.05);
      ctx.save(); ctx.translate(rx,ry); ctx.rotate(t*(.18-i*.04)+i*1.1);
      ctx.strokeStyle=`hsla(${(hue+i*60)%360},52%,78%,${.09-i*.02})`;
      ctx.lineWidth=.7; ctx.setLineDash([3,10+i*4]);
      ctx.beginPath(); ctx.arc(0,0,r,0,Math.PI*2); ctx.stroke();
      ctx.setLineDash([]); ctx.restore();
    }

    /* floating particles */
    specks.forEach(s=>{
      s.y -= s.vy/H; s.x += s.vx/W; s.a -= .00055;
      if(s.a<=0||s.y<-.02){s.x=Math.random();s.y=1.02;s.a=.06+Math.random()*.32;s.hue=Math.random()*360;}
      ctx.beginPath(); ctx.arc(s.x*W,s.y*H,s.r,0,Math.PI*2);
      ctx.fillStyle=`hsla(${s.hue},55%,82%,${s.a})`; ctx.fill();
    });

    t+=.012; requestAnimationFrame(draw);
  }
  draw();
})();


/* ══ PRODUCT CANVASES ══ */
const prodHues=[260,175,330];
document.querySelectorAll('.prod-canvas').forEach((cv,idx)=>{
  const ctx=cv.getContext('2d');
  let t=Math.random()*80;
  const base=prodHues[idx];
  function resize(){cv.width=cv.offsetWidth;cv.height=cv.offsetHeight;}
  resize();
  function draw(){
    const W=cv.width,H=cv.height;
    ctx.clearRect(0,0,W,H); ctx.fillStyle='#f2f1f5'; ctx.fillRect(0,0,W,H);
    const cx=W/2,cy=H*.5,hue=(base+t*11)%360;

    /* bg shimmer */
    const bg=ctx.createRadialGradient(cx,cy,0,cx,cy,H*.55);
    bg.addColorStop(0,`hsla(${hue},44%,88%,.4)`);
    bg.addColorStop(.55,`hsla(${(hue+60)%360},38%,92%,.15)`);
    bg.addColorStop(1,'transparent');
    ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);

    ctx.save(); ctx.translate(cx,cy);
    const bH=H*.5,bW=W*.22;

    /* iridescent bottle */
    const bg2=ctx.createLinearGradient(-bW,-bH/2,bW,bH/2);
    bg2.addColorStop(0,`hsla(${hue},48%,84%,.72)`);
    bg2.addColorStop(.25,`hsla(${(hue+50)%360},52%,90%,.88)`);
    bg2.addColorStop(.5,`hsla(${(hue+100)%360},46%,86%,.78)`);
    bg2.addColorStop(.75,`hsla(${(hue+155)%360},50%,88%,.82)`);
    bg2.addColorStop(1,`hsla(${(hue+210)%360},44%,82%,.62)`);
    ctx.fillStyle=bg2;
    ctx.beginPath(); ctx.roundRect(-bW,-bH/2,bW*2,bH,[bW*.48,bW*.48,bW*.28,bW*.28]); ctx.fill();
    ctx.strokeStyle=`hsla(${hue},38%,70%,.42)`; ctx.lineWidth=1;
    ctx.beginPath(); ctx.roundRect(-bW,-bH/2,bW*2,bH,[bW*.48,bW*.48,bW*.28,bW*.28]); ctx.stroke();

    /* cap */
    const capG=ctx.createLinearGradient(-bW*.6,-bH/2-bW*.8,bW*.6,-bH/2);
    capG.addColorStop(0,`hsla(${(hue+80)%360},35%,78%,.9)`);
    capG.addColorStop(1,`hsla(${(hue+20)%360},28%,68%,.7)`);
    ctx.fillStyle=capG;
    ctx.beginPath(); ctx.roundRect(-bW*.62,-bH/2-bW*.72,bW*1.24,bW*.8,[bW*.18]); ctx.fill();

    /* label */
    ctx.strokeStyle=`rgba(255,255,255,${.52+.1*Math.sin(t*1.1)})`;
    ctx.lineWidth=.6;
    ctx.beginPath(); ctx.roundRect(-bW*.72,-bH*.13,bW*1.44,bH*.3,4); ctx.stroke();

    /* shine */
    const sh=ctx.createLinearGradient(-bW*.28,-bH*.42,-bW*.1,bH*.3);
    sh.addColorStop(0,`rgba(255,255,255,${.58+.1*Math.sin(t*.7)})`);
    sh.addColorStop(.5,'rgba(255,255,255,.2)'); sh.addColorStop(1,'transparent');
    ctx.fillStyle=sh;
    ctx.beginPath(); ctx.roundRect(-bW*.28,-bH/2,bW*.18,bH,[bW*.09]); ctx.fill();

    ctx.restore();

    /* rings */
    for(let i=0;i<3;i++){
      const r=H*(.22+i*.09), rh=(hue+i*60)%360;
      ctx.save(); ctx.translate(cx,cy); ctx.rotate(t*.12*(i%2===0?1:-1));
      ctx.strokeStyle=`hsla(${rh},44%,72%,${.1-i*.025})`;
      ctx.lineWidth=.7; ctx.setLineDash([3,12+i*6]);
      ctx.beginPath(); ctx.arc(0,0,r,0,Math.PI*2); ctx.stroke();
      ctx.setLineDash([]); ctx.restore();
    }
    t+=.014; requestAnimationFrame(draw);
  }
  draw();
});

