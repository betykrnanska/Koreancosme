    ctx.lineWidth=1.3;
    ctx.beginPath(); ctx.moveTo(cx+W*.04,cy-H*.22);
    ctx.bezierCurveTo(cx+W*.08,cy-H*.18,cx+W*.09,cy-H*.1,cx+W*.07,cy);
    ctx.bezierCurveTo(cx+W*.06,cy+H*.06,cx+W*.03,cy+H*.1,cx,cy+H*.12); ctx.stroke();

    /* hand glow */
    const hg=ctx.createRadialGradient(cx-W*.05,cy+H*.09,0,cx,cy+H*.1,W*.09);
    hg.addColorStop(0,`hsla(${(hue+200)%360},50%,76%,${.48+.1*Math.sin(t*1.5)})`);
    hg.addColorStop(1,'transparent');
    ctx.fillStyle=hg; ctx.beginPath(); ctx.ellipse(cx-W*.04,cy+H*.1,W*.07,H*.055,.2,0,Math.PI*2); ctx.fill();

    /* orbiting specks */
    for(let i=0;i<48;i++){
      const a=(i/48)*Math.PI*2+t*.1;
      const r=H*(.3+.07*Math.sin(i*.7+t*.28));
      const px=cx+Math.cos(a)*r*.68, py=cy+Math.sin(a)*r;
      const sh=(hue+i*8)%360;
      const al=(.07+.07*Math.sin(i+t*2))*(.5+.3*Math.random());
      ctx.beginPath(); ctx.arc(px,py,.9+Math.random()*.8,0,Math.PI*2);
      ctx.fillStyle=`hsla(${sh},52%,72%,${al})`; ctx.fill();
    }

    /* silver lines */
    for(let i=0;i<8;i++){
      const y=H*.2+i*H*.08, len=W*(.12+.09*Math.sin(i*1.1+t*.5));
      ctx.strokeStyle=`rgba(130,138,158,${.14+.04*Math.sin(i+t)})`;
      ctx.lineWidth=.7;
      ctx.beginPath(); ctx.moveTo(cx+W*.16,y); ctx.lineTo(cx+W*.16+len,y); ctx.stroke();
    }
    t+=.01; requestAnimationFrame(draw);
  }
  draw();
})();

/* ══ INGREDIENT CANVAS ══ */
(function(){
  const cv=document.getElementById('ingredientCanvas'); if(!cv)return;
  const ctx=cv.getContext('2d'); let W,H,t=0;
  function resize(){W=cv.width=cv.offsetWidth;H=cv.height=cv.offsetHeight;}
  resize(); window.addEventListener('resize',resize);
  const nodes=Array.from({length:20},()=>({
    x:.12+Math.random()*.76, y:.08+Math.random()*.84,
    r:2.5+Math.random()*5, phase:Math.random()*Math.PI*2,
    speed:.25+Math.random()*.38, hue:Math.random()*360
  }));
  function draw(){
    ctx.clearRect(0,0,W,H); ctx.fillStyle='#f5f4f8'; ctx.fillRect(0,0,W,H);
    const mh=(t*13)%360;

    /* connections */
    for(let i=0;i<nodes.length;i++){
      for(let j=i+1;j<nodes.length;j++){
        const ax=nodes[i].x*W, ay=nodes[i].y*H+Math.sin(t*nodes[i].speed+nodes[i].phase)*10;
        const bx=nodes[j].x*W, by=nodes[j].y*H+Math.sin(t*nodes[j].speed+nodes[j].phase)*10;
        const d=Math.hypot(ax-bx,ay-by);
        if(d<W*.3){
          const al=(1-d/(W*.3))*.14;
          ctx.strokeStyle=`hsla(${(mh+(i+j)*18)%360},40%,68%,${al})`;
          ctx.lineWidth=.6; ctx.beginPath(); ctx.moveTo(ax,ay); ctx.lineTo(bx,by); ctx.stroke();
        }
      }
    }

    /* nodes */
    nodes.forEach((n,i)=>{
      const x=n.x*W, y=n.y*H+Math.sin(t*n.speed+n.phase)*10;
      const pulse=1+.14*Math.sin(t*n.speed*1.2+n.phase);
      const nh=(mh+i*20)%360;
      const g=ctx.createRadialGradient(x,y,0,x,y,n.r*3.2*pulse);
      g.addColorStop(0,`hsla(${nh},50%,74%,.55)`);
      g.addColorStop(.45,`hsla(${(nh+40)%360},44%,80%,.12)`);
      g.addColorStop(1,'transparent');
      ctx.fillStyle=g; ctx.beginPath(); ctx.arc(x,y,n.r*3.2*pulse,0,Math.PI*2); ctx.fill();
      ctx.beginPath(); ctx.arc(x,y,n.r*pulse*.38,0,Math.PI*2);
      ctx.fillStyle=`hsla(${nh},44%,62%,.85)`; ctx.fill();
      ctx.beginPath(); ctx.arc(x-n.r*.12,y-n.r*.12,n.r*.12*pulse,0,Math.PI*2);
      ctx.fillStyle='rgba(255,255,255,.75)'; ctx.fill();
    });

    /* center glow */
    const cg=ctx.createRadialGradient(W/2,H/2,0,W/2,H/2,H*.45);
    cg.addColorStop(0,`rgba(175,180,200,${.07+.025*Math.sin(t*.4)})`);
    cg.addColorStop(1,'transparent');
    ctx.fillStyle=cg; ctx.fillRect(0,0,W,H);

    t+=.016; requestAnimationFrame(draw);
  }
  draw();
})();

/* ══ ARTIST CANVASES ══ */
document.querySelectorAll('.artist-canvas').forEach(cv => {
  const ctx = cv.getContext('2d');
  const baseHue = parseInt(cv.dataset.hue) || 200;
  const featured = !!cv.dataset.featured;
  let t = Math.random() * 100;

  function resize() { cv.width = cv.offsetWidth; cv.height = cv.offsetHeight; }
  resize();

  // Each artist card gets a unique generative portrait feel
  const nodes = Array.from({length: featured ? 28 : 16}, () => ({
    x: Math.random(), y: Math.random(),
    vx: (Math.random()-.5)*.0006, vy: (Math.random()-.5)*.0006,
    r: 1.5 + Math.random() * (featured ? 5 : 3.5),
    phase: Math.random() * Math.PI * 2,
    speed: .2 + Math.random() * .35,
    hue: baseHue + (Math.random()-.5)*80,
  }));

  function draw() {
    const W = cv.width, H = cv.height;
    ctx.clearRect(0,0,W,H);

    // dark base
    ctx.fillStyle = '#0c0c14'; ctx.fillRect(0,0,W,H);

    const hue = (baseHue + t * 8) % 360;

    // deep atmospheric glow — signature per artist
    const atmo = ctx.createRadialGradient(W*.5, H*.42, 0, W*.5, H*.5, Math.max(W,H)*.85);
    atmo.addColorStop(0, `hsla(${hue},45%,30%,${.35+.06*Math.sin(t*.3)})`);
    atmo.addColorStop(.4, `hsla(${(hue+60)%360},38%,22%,.18)`);
    atmo.addColorStop(.75, `hsla(${(hue+130)%360},30%,15%,.08)`);
    atmo.addColorStop(1, 'transparent');
    ctx.fillStyle = atmo; ctx.fillRect(0,0,W,H);

    // figure silhouette — abstract face halo
    const fHue = (hue+180)%360;
    const cx = W*.5, cy = H*(featured?.4:.42);
    const fh = ctx.createRadialGradient(cx,cy,0,cx,cy,H*(featured?.35:.3));
    fh.addColorStop(0,`hsla(${fHue},50%,72%,${.22+.05*Math.sin(t*.4)})`);
    fh.addColorStop(.4,`hsla(${(fHue+40)%360},42%,60%,.1)`);
    fh.addColorStop(1,'transparent');
    ctx.fillStyle=fh;
    ctx.beginPath();
    ctx.ellipse(cx,cy,W*(featured?.1:.12),H*(featured?.2:.18),0,0,Math.PI*2);
    ctx.fill();

    // body suggestion
    const bodyG = ctx.createLinearGradient(cx,H*.55,cx,H);
    bodyG.addColorStop(0,`hsla(${hue},28%,45%,.2)`);
    bodyG.addColorStop(1,'transparent');
    ctx.fillStyle=bodyG;
    ctx.beginPath();
    ctx.moveTo(cx-W*.2,H); ctx.bezierCurveTo(cx-W*.16,H*.76,cx-W*.09,H*.63,cx,H*.57);
    ctx.bezierCurveTo(cx+W*.09,H*.63,cx+W*.16,H*.76,cx+W*.2,H); ctx.fill();

    // iridescent orbiting particles / nodes
    nodes.forEach(n => {
      n.x += n.vx; n.y += n.vy;
      if(n.x<0||n.x>1) n.vx*=-1;
      if(n.y<0||n.y>1) n.vy*=-1;
      const px=n.x*W, py=n.y*H;
      const pulse=1+.12*Math.sin(t*n.speed+n.phase);
      const nh=(n.hue+t*6)%360;
      const g=ctx.createRadialGradient(px,py,0,px,py,n.r*3.5*pulse);
      g.addColorStop(0,`hsla(${nh},55%,75%,.45)`);
      g.addColorStop(.5,`hsla(${(nh+50)%360},48%,68%,.1)`);
      g.addColorStop(1,'transparent');
      ctx.fillStyle=g; ctx.beginPath(); ctx.arc(px,py,n.r*3.5*pulse,0,Math.PI*2); ctx.fill();
      ctx.beginPath(); ctx.arc(px,py,n.r*.42*pulse,0,Math.PI*2);
      ctx.fillStyle=`hsla(${nh},50%,78%,.82)`; ctx.fill();
    });

    // iridescent ring / halo for artist
    for(let i=0;i<3;i++){
      const r=Math.min(W,H)*(featured?(.24+i*.07):(.2+i*.06));
      const a=t*(.13-i*.03)+i*1.2;
      const rh=(hue+i*60)%360;
      ctx.save(); ctx.translate(cx,cy); ctx.rotate(a);
      ctx.strokeStyle=`hsla(${rh},50%,70%,${.1-i*.025})`;
      ctx.lineWidth=.8; ctx.setLineDash([4,12+i*5]);
      ctx.beginPath(); ctx.ellipse(0,0,r*(.55+i*.06),r,i*.28,0,Math.PI*2); ctx.stroke();
      ctx.setLineDash([]); ctx.restore();
    }

    // horizontal light streaks — gallery atmosphere
    for(let i=0;i<5;i++){
      const sy=H*(.15+i*.17)+Math.sin(t*.2+i)*H*.03;
      const len=W*(featured?(.3+.15*Math.sin(i+t*.3)):(.2+.12*Math.sin(i+t*.3)));
      const sx=W*(featured?.12:.1)+Math.sin(t*.15+i)*W*.05;
      const lh=(hue+i*30)%360;
      const lg=ctx.createLinearGradient(sx,sy,sx+len,sy);
      lg.addColorStop(0,'transparent');
      lg.addColorStop(.3,`hsla(${lh},45%,70%,${.12+.04*Math.sin(t+i)})`);
      lg.addColorStop(.7,`hsla(${(lh+40)%360},40%,72%,.08)`);
      lg.addColorStop(1,'transparent');
      ctx.strokeStyle=lg; ctx.lineWidth=.7;
      ctx.beginPath(); ctx.moveTo(sx,sy); ctx.lineTo(sx+len,sy); ctx.stroke();
    }

    // vignette
    const vig=ctx.createRadialGradient(W/2,H/2,H*.2,W/2,H/2,H*.9);
    vig.addColorStop(0,'transparent'); vig.addColorStop(1,'rgba(6,6,10,.65)');
    ctx.fillStyle=vig; ctx.fillRect(0,0,W,H);

    t+=.012; requestAnimationFrame(draw);
  }
  draw();
});

/* ══ MUSIC PLAYER — YouTube IFrame API ══ */
(function(){
  const btn       = document.getElementById('musicBtn');
  const bars      = document.getElementById('musicBars');
  const pauseIcon = document.getElementById('musicPauseIcon');
  const tooltip   = document.getElementById('musicTooltip');
  let player, ready = false, playing = false;

  /* Load YouTube IFrame API */
  const tag = document.createElement('script');
  tag.src = 'https://www.youtube.com/iframe_api';
  document.head.appendChild(tag);

  window.onYouTubeIframeAPIReady = function(){
    player = new YT.Player('ytPlayer', {
      height:'1', width:'1',
      videoId: 'dNCWe_6HAM8',
      playerVars: {
        autoplay: 0,
        controls: 0,
        disablekb: 1,
        fs: 0,
        iv_load_policy: 3,
        modestbranding: 1,
        rel: 0,
        start: 0
      },
      events: {
        onReady: () => { ready = true; },
        onStateChange: (e) => {
          if(e.data === YT.PlayerState.PLAYING){
            setPlaying(true);
          } else if(e.data === YT.PlayerState.PAUSED || e.data === YT.PlayerState.ENDED){
            setPlaying(false);
          }
        }
      }
    });
  };

  function setPlaying(state){
    playing = state;
    btn.classList.toggle('playing', state);
    bars.style.display      = state ? 'flex'  : 'flex';
    pauseIcon.style.display = state ? 'block' : 'none';
    bars.style.display      = state ? 'none'  : 'flex';
    tooltip.textContent     = state ? 'NOW PLAYING — PAUSE' : 'LISA — MONEY';
  }

  btn.addEventListener('click', () => {
    if(!ready) return;
    if(playing){
      player.pauseVideo();
    } else {
      player.playVideo();
    }
  });

  /* Tooltip show on hover */
  btn.addEventListener('mouseenter', () => tooltip.classList.add('visible'));
  btn.addEventListener('mouseleave', () => tooltip.classList.remove('visible'));
})();

