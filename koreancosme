<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>KOREANCOSME</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Syncopate:wght@400;700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --white:   #ffffff;
      --offwhite:#f8f7f6;
      --pale:    #f1f0f4;
      --silver:  #a8adb8;
      --silver2: #d0d4dc;
      --black:   #0a0a0c;
      --ink:     #1a1a22;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--white);
      color: var(--ink);
      font-family: 'Space Mono', monospace;
      overflow-x: hidden;
      cursor: none;
    }

    /* ── CURSOR ──────────────────────────────────────── */
    .cursor {
      position: fixed; top: 0; left: 0;
      width: 10px; height: 10px;
      background: var(--black); border-radius: 50%;
      pointer-events: none; z-index: 9999;
      transform: translate(-50%,-50%);
      transition: width .18s, height .18s;
    }
    .cursor-ring {
      position: fixed; top: 0; left: 0;
      width: 34px; height: 34px;
      border: 1px solid var(--silver); border-radius: 50%;
      pointer-events: none; z-index: 9998;
      transform: translate(-50%,-50%);
      transition: transform .18s ease; opacity: .5;
    }

    /* ── NAV ─────────────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      background: rgba(255,255,255,0.97);
      backdrop-filter: blur(28px);
      border-bottom: 1px solid rgba(0,0,0,0.08);
    }
    .nav-top {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 52px; height: 64px;
    }
    .nav-logo {
      font-family: 'Syncopate', sans-serif;
      font-weight: 700; font-size: 13px;
      letter-spacing: 0.34em; color: var(--black); text-decoration: none;
      flex-shrink: 0;
    }
    .nav-links {
      display: flex; gap: 0; list-style: none; height: 100%;
    }
    .nav-links > li {
      position: relative; height: 64px;
      display: flex; align-items: center;
    }
    .nav-links > li > a {
      font-family: 'Syncopate', sans-serif;
      font-size: 8.5px; letter-spacing: 0.22em; font-weight: 700;
      color: var(--black); text-decoration: none;
      padding: 0 22px; height: 100%;
      display: flex; align-items: center;
      position: relative;
      transition: color .25s, background .25s;
    }
    .nav-links > li > a::after {
      content: '';
      position: absolute; bottom: 0; left: 22px; right: 22px;
      height: 2px;
      background: linear-gradient(90deg,#9bbfe6,#c9a8e8,#90e0d0);
      transform: scaleX(0); transform-origin: left;
      transition: transform .3s ease;
    }
    .nav-links > li:hover > a { color: var(--black); background: rgba(0,0,0,.025); }
    .nav-links > li:hover > a::after { transform: scaleX(1); }
    .nav-links > li > a .caret {
      margin-left: 5px; font-size: 7px; opacity: .45;
      transition: transform .25s;
    }
    .nav-links > li:hover > a .caret { transform: rotate(180deg); }

    /* nav right extras */
    .nav-extras {
      display: flex; align-items: center; gap: 20px; flex-shrink: 0;
    }
    .nav-extras a {
      font-family: 'Syncopate', sans-serif; font-size: 7.5px;
      letter-spacing: .22em; color: var(--ink); text-decoration: none;
      opacity: .5; transition: opacity .25s;
    }
    .nav-extras a:hover { opacity: 1; }
    .nav-extras .nav-contact-btn {
      background: var(--black); color: var(--white);
      padding: 9px 20px; font-size: 7px; letter-spacing: .26em;
      opacity: 1; font-family: 'Syncopate', sans-serif;
      transition: background .25s;
    }
    .nav-extras .nav-contact-btn:hover { background: #2a2a38; }

    /* ── MEGA DROPDOWN ── */
    .nav-dropdown {
      position: absolute; top: 64px; left: 0;
      min-width: 240px;
      background: rgba(255,255,255,0.99);
      border: 1px solid rgba(0,0,0,0.07);
      border-top: 2px solid transparent;
      border-image: linear-gradient(90deg,#9bbfe6,#c9a8e8,#90e0d0) 1;
      box-shadow: 0 16px 48px rgba(0,0,0,.1);
      opacity: 0; visibility: hidden;
      transform: translateY(-8px);
      transition: opacity .28s ease, transform .28s ease, visibility .28s;
      pointer-events: none;
    }
    .nav-links > li:hover .nav-dropdown {
      opacity: 1; visibility: visible;
      transform: translateY(0); pointer-events: auto;
    }
    .nav-dropdown-inner { padding: 12px 0; }
    .nav-dropdown-label {
      font-family: 'Syncopate', sans-serif; font-size: 7px;
      letter-spacing: .42em; color: var(--silver);
      padding: 12px 24px 8px; display: block;
    }
    .nav-dropdown a {
      display: flex; align-items: center; justify-content: space-between;
      font-family: 'Space Mono', monospace; font-size: 10px;
      color: var(--ink); text-decoration: none;
      padding: 10px 24px; gap: 12px;
      transition: background .2s, color .2s;
    }
    .nav-dropdown a:hover {
      background: var(--pale); color: var(--black);
    }
    .nav-dropdown a .sub-arrow {
      font-size: 9px; opacity: 0; transition: opacity .2s, transform .2s;
      background: linear-gradient(90deg,#9bbfe6,#c9a8e8);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .nav-dropdown a:hover .sub-arrow { opacity: 1; transform: translateX(3px); }
    .nav-dropdown hr {
      border: none; border-top: 1px solid rgba(0,0,0,.06); margin: 6px 0;
    }

    @media(max-width:900px){
      .nav-top { padding: 0 22px; }
      .nav-links > li > a { padding: 0 14px; font-size: 7.5px; }
      .nav-extras .nav-contact-btn { display: none; }
    }
    @media(max-width:680px){
      .nav-links { display: none; }
      .nav-extras { gap: 12px; }
    }

    /* ── HERO ────────────────────────────────────────── */
    .hero {
      position: relative; width: 100vw; height: 100vh;
      overflow: hidden; display: flex; align-items: flex-end;
      background: var(--black);
    }
    #heroVideo {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center center;
      filter: saturate(1.15) contrast(1.08) brightness(0.93);
      transform: translateZ(0) scale(1.001);
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
      will-change: transform;
      z-index: 0;
    }
    #heroParticleCanvas {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      z-index: 1; pointer-events: none;
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background:
        linear-gradient(to top, rgba(10,10,14,.88) 0%, rgba(10,10,14,.22) 40%, rgba(10,10,14,.04) 62%, transparent 80%),
        linear-gradient(to right, rgba(10,10,14,.65) 0%, rgba(10,10,14,.08) 48%, transparent 68%);
      z-index: 2;
    }
    .scanlines {
      position: absolute; inset: 0;
      background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,.01) 3px, rgba(0,0,0,.01) 4px);
      z-index: 3; pointer-events: none;
    }
    .hero-content { position: relative; z-index: 4; padding: 0 52px 80px; max-width: 800px; }
    .hero-eyebrow {
      font-family: 'Syncopate', sans-serif; font-size: 8px; letter-spacing: .44em;
      color: var(--silver2); margin-bottom: 20px;
      animation: fadeUp 1.1s ease .3s both;
    }
    .hero-title {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(54px, 7.5vw, 114px);
      line-height: .9; font-weight: 400; letter-spacing: -.02em; color: var(--white);
      margin-bottom: 30px; animation: fadeUp 1.1s ease .5s both;
    }
    .hero-title .iri {
      background: linear-gradient(115deg, #9bbfe6 0%, #c9a8e8 30%, #90e0d0 58%, #e6b8a0 80%, #e8a0bc 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      font-style: italic;
    }
    .hero-sub {
      font-size: 10px; letter-spacing: .14em; line-height: 2.1; color: var(--silver2); max-width: 340px;
      animation: fadeUp 1.1s ease .7s both;
    }
    .hero-cta {
      margin-top: 44px; display: flex; gap: 18px; align-items: center;
      animation: fadeUp 1.1s ease .9s both;
    }
    .btn-primary {
      font-family: 'Syncopate', sans-serif; font-size: 8px; letter-spacing: .3em;
      background: var(--black); color: var(--white); border: none; padding: 16px 36px;
      cursor: none; text-decoration: none; display: inline-block;
      transition: background .3s, transform .2s;
    }
    .btn-primary:hover { background: #2a2a38; transform: translateY(-2px); }
    .btn-ghost {
      font-family: 'Syncopate', sans-serif; font-size: 8px; letter-spacing: .3em;
      background: transparent; color: var(--white);
      border: 1px solid rgba(255,255,255,.28);
      padding: 16px 36px; cursor: none; text-decoration: none; display: inline-block;
      transition: border-color .3s, color .3s;
    }
    .btn-ghost:hover { border-color: var(--silver2); color: var(--silver2); }

    .scroll-ind {
      position: absolute; bottom: 34px; right: 52px; z-index: 5;
      display: flex; flex-direction: column; align-items: center; gap: 10px;
      animation: fadeUp 1.4s ease 1.2s both;
    }
    .scroll-ind span {
      font-family: 'Syncopate', sans-serif; font-size: 7px; letter-spacing: .36em;
      color: var(--silver2); writing-mode: vertical-lr;
    }
    .scroll-line {
      width: 1px; height: 58px;
      background: linear-gradient(to bottom, var(--silver2), transparent);
      animation: scrollPulse 2.2s ease infinite;
    }

    /* ── TICKER ──────────────────────────────────────── */
    .featured-strip {
      overflow: hidden;
      border-top: 1px solid rgba(0,0,0,.065);
      border-bottom: 1px solid rgba(0,0,0,.065);
      background: var(--offwhite);
    }
    .ticker { display: flex; animation: tickerMove 26s linear infinite; white-space: nowrap; }
    .ticker-item {
      font-family: 'Syncopate', sans-serif; font-size: 8px; letter-spacing: .4em;
      padding: 17px 46px; color: var(--silver);
      border-right: 1px solid rgba(0,0,0,.055); flex-shrink: 0;
    }
    .ticker-item.hi {
      background: linear-gradient(90deg,#9bbfe6,#c9a8e8,#90e0d0);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }

    /* ── SECTIONS ────────────────────────────────────── */
    .section { padding: 120px 52px; background: var(--white); }
    .section.pale { background: var(--pale); }
    .section-label {
      font-family: 'Syncopate', sans-serif; font-size: 7px; letter-spacing: .52em;
      color: var(--silver); margin-bottom: 16px;
    }
    .section-title {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(32px,4vw,62px); font-weight: 400; line-height: 1.08;
      margin-bottom: 60px; max-width: 560px; color: var(--black);
    }
    .section-title em {
      font-style: italic;
      background: linear-gradient(100deg,#9bbfe6 0%,#c9a8e8 50%,#90e0d0 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }

    /* ── PRODUCT GRID ────────────────────────────────── */
    .grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 2px; }
    .product-card {
      position: relative; overflow: hidden; aspect-ratio: 3/4;
      background: var(--pale); cursor: none;
    }
    .product-card canvas { width: 100%; height: 100%; display: block; }
    .product-card-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(10,10,12,.82) 0%, transparent 55%);
      opacity: 0; transition: opacity .4s;
    }
    .product-card:hover .product-card-overlay { opacity: 1; }
    .product-card-info {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 26px 22px; transform: translateY(8px); opacity: 0; transition: all .4s;
    }
    .product-card:hover .product-card-info { opacity: 1; transform: translateY(0); }
    .product-card-name { font-family: 'DM Serif Display', serif; font-size: 20px; color: var(--white); margin-bottom: 5px; }
    .product-card-sub { font-size: 8px; letter-spacing: .22em; color: var(--silver2); }

    /* ── FEATURE FULL ────────────────────────────────── */
    .feature-full { position: relative; width: 100%; height: 78vh; overflow: hidden; display: flex; align-items: center; }
    #featureCanvas { position: absolute; inset: 0; width: 100%; height: 100%; }
    .feature-full-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to right, rgba(248,247,246,.94) 36%, rgba(248,247,246,.08) 72%, transparent);
    }
    .feature-content { position: relative; z-index: 2; padding: 0 80px; max-width: 540px; }
    .feature-tag { font-family: 'Syncopate', sans-serif; font-size: 7px; letter-spacing: .44em; color: var(--silver); margin-bottom: 20px; }
    .feature-headline { font-family: 'DM Serif Display', serif; font-size: clamp(36px,4vw,58px); color: var(--black); line-height: 1.05; margin-bottom: 22px; }
    .feature-desc { font-size: 10px; line-height: 2.2; color: var(--silver); max-width: 380px; margin-bottom: 34px; }

    /* ── INGREDIENTS ─────────────────────────────────── */
    .ingredients { padding: 110px 52px; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; background: var(--white); }
    .ingredient-visual { position: relative; height: 500px; }
    #ingredientCanvas { width: 100%; height: 100%; }
    .ingredient-item {
      border-bottom: 1px solid rgba(0,0,0,.065); padding: 26px 0;
      display: flex; justify-content: space-between; align-items: flex-start;
      cursor: none; transition: border-color .3s;
    }
    .ingredient-item:hover { border-color: var(--silver); }
    .ingredient-name { font-family: 'DM Serif Display', serif; font-size: 21px; color: var(--black); }
    .ingredient-origin { font-family: 'Syncopate', sans-serif; font-size: 7px; letter-spacing: .3em; color: var(--silver); margin-top: 6px; }
    .ingredient-num { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--silver2); }

    /* ── EXHIBITION ──────────────────────────────────── */
    .exhibition {
      padding: 130px 52px;
      background: var(--black);
      position: relative; overflow: hidden;
    }
    .exhibition::before {
      content: '';
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 70% 55% at 80% 40%, hsla(260,45%,40%,.18) 0%, transparent 70%),
        radial-gradient(ellipse 50% 40% at 20% 70%, hsla(175,45%,35%,.14) 0%, transparent 65%);
      pointer-events: none;
    }
    .exhibition-header {
      display: flex; justify-content: space-between; align-items: flex-end;
      margin-bottom: 72px; position: relative; z-index: 2;
    }
    .exhibition-header-left { max-width: 540px; }
    .exhibition .section-label { color: var(--silver2); margin-bottom: 16px; }
    .exhibition-title {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(34px,4.5vw,66px);
      font-weight: 400; line-height: 1.04; color: var(--white);
    }
    .exhibition-title em {
      font-style: italic;
      background: linear-gradient(115deg,#9bbfe6 0%,#c9a8e8 35%,#90e0d0 65%,#e8b8a0 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .exhibition-meta {
      text-align: right;
    }
    .exhibition-venue {
      font-family: 'Syncopate', sans-serif;
      font-size: 8px; letter-spacing: .38em; color: var(--silver); margin-bottom: 6px;
    }
    .exhibition-dates {
      font-family: 'DM Serif Display', serif;
      font-size: 22px; color: var(--white); font-style: italic;
    }
    .exhibition-address {
      font-size: 9px; letter-spacing: .14em; color: var(--silver); margin-top: 6px;
    }

    /* artist grid */
    .artist-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 2px;
      position: relative; z-index: 2;
      margin-bottom: 2px;
    }
    .artist-card {
      position: relative; overflow: hidden;
      aspect-ratio: 4/5;
      background: #111118;
      cursor: none;
    }
    .artist-card.featured {
      grid-column: span 2;
      aspect-ratio: unset;
    }
    .artist-card canvas { width: 100%; height: 100%; display: block; }
    .artist-card-glass {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(10,10,14,.9) 0%, rgba(10,10,14,.2) 45%, transparent 70%);
      transition: background .4s;
    }
    .artist-card:hover .artist-card-glass {
      background: linear-gradient(to top, rgba(10,10,14,.95) 0%, rgba(10,10,14,.45) 55%, rgba(10,10,14,.08) 80%);
    }
    .artist-card-body {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 30px 28px; z-index: 2;
    }
    .artist-number {
      font-family: 'Syncopate', sans-serif; font-size: 7px;
      letter-spacing: .44em; color: var(--silver); margin-bottom: 10px;
      opacity: .7;
    }
    .artist-name {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(22px, 2.2vw, 34px); color: var(--white);
      line-height: 1.1; margin-bottom: 6px;
    }
    .artist-card.featured .artist-name { font-size: clamp(28px,3vw,50px); }
    .artist-medium {
      font-size: 9px; letter-spacing: .2em; color: var(--silver); margin-bottom: 14px;
    }
    .artist-desc {
      font-size: 10px; line-height: 1.95; color: rgba(200,202,212,.6);
      max-width: 440px;
      max-height: 0; overflow: hidden;
      transition: max-height .5s ease, opacity .4s ease;
      opacity: 0;
    }
    .artist-card:hover .artist-desc { max-height: 120px; opacity: 1; }
    .artist-tag {
      display: inline-block;
      font-family: 'Syncopate', sans-serif; font-size: 7px; letter-spacing: .28em;
      border: 1px solid rgba(255,255,255,.14);
      padding: 5px 14px; color: var(--silver);
      margin-top: 16px;
      transition: border-color .3s, color .3s;
    }
    .artist-card:hover .artist-tag {
      border-color: rgba(155,191,230,.5); color: #9bbfe6;
    }

    /* bottom strip */
    .exhibition-bottom {
      display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 2px;
      position: relative; z-index: 2;
    }
    .exh-info-panel {
      background: #0e0e14; padding: 36px 32px;
    }
    .exh-info-label {
      font-family: 'Syncopate', sans-serif; font-size: 7px;
      letter-spacing: .44em; color: var(--silver); margin-bottom: 14px; opacity: .6;
    }
    .exh-info-value {
      font-family: 'DM Serif Display', serif; font-size: 18px; color: var(--white); font-weight: 400;
      line-height: 1.5;
    }
    .exh-info-sub {
      font-size: 9px; letter-spacing: .12em; color: var(--silver); margin-top: 8px; opacity: .55;
    }
    .exh-rsvp {
      background: var(--white); padding: 36px 32px;
      display: flex; flex-direction: column; justify-content: space-between;
    }
    .exh-rsvp-title {
      font-family: 'DM Serif Display', serif; font-size: 24px; color: var(--black); font-style: italic;
    }
    .exh-rsvp-sub { font-size: 9px; letter-spacing: .14em; color: var(--silver); margin-top: 8px; }
    .btn-rsvp {
      font-family: 'Syncopate', sans-serif; font-size: 8px; letter-spacing: .3em;
      background: var(--black); color: var(--white);
      border: none; padding: 14px 28px; cursor: none;
      text-decoration: none; display: inline-block; align-self: flex-start;
      transition: background .3s;
    }
    .btn-rsvp:hover { background: #2a2a38; }

    @media(max-width:768px){
      .exhibition{padding:70px 22px;}
      .exhibition-header{flex-direction:column;align-items:flex-start;gap:24px;}
      .exhibition-meta{text-align:left;}
      .artist-grid{grid-template-columns:1fr;}
      .artist-card.featured{grid-column:span 1;}
      .exhibition-bottom{grid-template-columns:1fr;}
    }

    /* ── MUSIC BUTTON ────────────────────────────────── */
    .music-btn {
      position: fixed; bottom: 36px; right: 36px; z-index: 200;
      width: 52px; height: 52px; border-radius: 50%;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(0,0,0,0.08);
      display: flex; align-items: center; justify-content: center;
      cursor: none;
      box-shadow: 0 4px 24px rgba(0,0,0,0.1);
      transition: transform .25s ease, box-shadow .25s ease, background .25s;
    }
    .music-btn:hover {
      transform: scale(1.1);
      box-shadow: 0 6px 32px rgba(155,191,230,0.38);
    }
    .music-btn.playing {
      background: var(--black);
      box-shadow: 0 4px 28px rgba(155,191,230,0.28);
    }
    .music-btn svg { width: 18px; height: 18px; }
    .music-btn .music-bars {
      display: flex; gap: 3px; align-items: flex-end; height: 18px;
    }
    .music-btn .bar {
      width: 3px; border-radius: 2px;
      background: linear-gradient(to top, #9bbfe6, #c9a8e8);
      animation: barBounce 1.1s ease-in-out infinite;
    }
    .music-btn.playing .bar {
      background: linear-gradient(to top, #9bbfe6, #c9a8e8);
    }
    .music-btn .bar:nth-child(1){ height: 8px;  animation-delay: 0s; }
    .music-btn .bar:nth-child(2){ height: 14px; animation-delay: .18s; }
    .music-btn .bar:nth-child(3){ height: 10px; animation-delay: .36s; }
    .music-btn .bar:nth-child(4){ height: 16px; animation-delay: .1s; }
    .music-btn .bar:nth-child(5){ height: 7px;  animation-delay: .28s; }
